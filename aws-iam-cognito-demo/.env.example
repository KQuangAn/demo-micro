# ──────────────────────────────────────────
# AWS credentials (your own IAM user)
# ──────────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_KEY

# ──────────────────────────────────────────
# IAM Role to assume (create one first)
# ──────────────────────────────────────────
ROLE_TO_ASSUME_ARN=arn:aws:iam::123456789012:role/DemoAssumeRole

# ──────────────────────────────────────────
# Cognito User Pool (create via console or Terraform)
# ──────────────────────────────────────────
COGNITO_USER_POOL_ID=ap-southeast-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────
# Cognito Identity Pool
# ──────────────────────────────────────────
COGNITO_IDENTITY_POOL_ID=ap-southeast-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ──────────────────────────────────────────
# Test user
# ──────────────────────────────────────────
TEST_USERNAME=testuser@example.com
TEST_PASSWORD=Test@12345678
