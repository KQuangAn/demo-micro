# Mailchimp API key (from Account > Extras > API Keys)
MAILCHIMP_API_KEY=your-api-key-here

# Secret token appended to your webhook URL for basic auth
# Register webhook as: https://yoursite.com/webhooks/mailchimp?secret=your-secret
MAILCHIMP_WEBHOOK_SECRET=your-webhook-secret-here

# Path to the Excel file where events will be appended
EXCEL_FILE_PATH=./data/mailchimp_events.xlsx
